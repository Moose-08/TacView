{
  "name": "tacview",
  "version": "0.3.0",
  "description": "Cyber-military tactical map webapp for War Thunder's localhost:8111 API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "stop": "powershell -NoProfile -Command \"Stop-Process -Id (Get-NetTCPConnection -LocalPort 3111 -State Listen).OwningProcess -Force\"",
    "build:ext": "node scripts/build-ext.mjs",
    "build:exe": "node scripts/build-exe.mjs",
    "overlay": "powershell -NoProfile -ExecutionPolicy Bypass -File overlay.ps1"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "rcedit": "^5.0.2"
  }
}
