{
  "manifest_version": 3,
  "name": "TACVIEW",
  "version": "0.2.0",
  "description": "Cyber-military tactical map for War Thunder. Reads the game's localhost:8111 telemetry API and renders a live command display.",
  "browser_specific_settings": {
    "gecko": {
      "id": "tacview@local"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open TACVIEW",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "host_permissions": [
    "http://localhost:8111/*",
    "http://127.0.0.1:8111/*"
  ]
}
